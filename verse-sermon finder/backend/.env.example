# Get a free key: console.cloud.google.com -> new project -> enable
# "YouTube Data API v3" -> Credentials -> Create Credentials -> API key.
# See README.md for the full walkthrough.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# SQLite by default - no setup needed. Swap for Postgres/MySQL later,
# e.g. postgresql://user:password@localhost:5432/bible_app
DATABASE_URL=sqlite:///./bible_app.db

# Free, no-key Bible full-text search API.
BIBLE_SEARCH_URL=https://judeasoftware.com/api/kjv/search.php
